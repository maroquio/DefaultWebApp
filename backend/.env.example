# =============================================================================
# WebSPA — Backend (API JSON). Copie para .env e ajuste.
# Configuração híbrida: banco (tabela configuracao) → .env → default no código.
# =============================================================================

# === Aplicação ===
APP_NAME=SeuProjeto
# Chave de sessão/cookie. Em produção deve ter >= 32 chars e ser única.
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=cole_a_chave_de_sessao_aqui
# Modo de execução: Development (erros detalhados, sem catch-all SPA) ou Production.
RUNNING_MODE=Development
# Timezone da aplicação (datetimes saem em ISO 8601 com este offset).
TIMEZONE=America/Sao_Paulo

# URL base da aplicação. Usada nos links de e-mail (que apontam para o SPA, ex.
# redefinição de senha) e nas back_urls/webhook enviados aos provedores de pagamento.
# Em dev geralmente é a origem do SPA (Vite). Em prod, o domínio público (https).
BASE_URL=http://localhost:8400

# === Servidor ===
# Em dev o SPA roda no Vite e faz proxy de /api para este HOST:PORT (same-origin).
HOST=127.0.0.1
# Porta padrão de DEV é 8400 (o Vite proxia /api -> :8400). A porta INTERNA do
# container em produção é 8000; o host publica 8410 (starter kit) -> ver deploy/.
PORT=8400
# Hot reload (apenas em desenvolvimento).
RELOAD=True

# === Frontend (SPA em produção) ===
# Caminho do build do React (dist/). Em produção, se existir e RUNNING_MODE!=Development,
# o FastAPI serve o index.html via catch-all e os assets em /assets.
SPA_DIST_PATH=../frontend/dist

# === Banco de Dados ===
DATABASE_PATH=dados.db

# === Logging ===
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30

# === Email (Resend.com) ===
# RESEND_API_KEY: gere em https://resend.com/
RESEND_API_KEY=cole_a_chave_de_api_do_resend_aqui
RESEND_FROM_EMAIL=seuprojeto@ifes.site
RESEND_FROM_NAME="Seu Projeto"

# === Fotos de Perfil (upload via base64 no JSON) ===
FOTO_PERFIL_TAMANHO_MAX=256
FOTO_MAX_UPLOAD_BYTES=5242880

# === Senha ===
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128

# === Interface (consumido pelo SPA) ===
TOAST_AUTO_HIDE_DELAY_MS=5000

# =============================================================================
# Pagamentos (todos os webhooks são isentos de CSRF/autenticação)
# =============================================================================
# Provedor de pagamento ativo: mercadopago, stripe ou paypal (default: mercadopago).
PAYMENT_PROVIDER=mercadopago
# Mercado Pago — use credenciais TEST- para sandbox; APP_USR- para produção.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# =============================================================================
# Rate Limiting (MAX requisições por janela de MINUTOS, por IP).
# Ajustáveis em runtime via PUT /api/admin/configuracoes (sem reiniciar).
# Resposta ao exceder: HTTP 429 + header Retry-After.
# =============================================================================

# Autenticação
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_MINUTOS=5
RATE_LIMIT_CADASTRO_MAX=3
RATE_LIMIT_CADASTRO_MINUTOS=10
RATE_LIMIT_ESQUECI_SENHA_MAX=1
RATE_LIMIT_ESQUECI_SENHA_MINUTOS=1

# Upload de Foto de Perfil
RATE_LIMIT_UPLOAD_FOTO_MAX=5
RATE_LIMIT_UPLOAD_FOTO_MINUTOS=10

# Alteração de Senha
RATE_LIMIT_ALTERAR_SENHA_MAX=5
RATE_LIMIT_ALTERAR_SENHA_MINUTOS=15

# Formulários GET (carregamento de dados de edição)
RATE_LIMIT_FORM_GET_MAX=60
RATE_LIMIT_FORM_GET_MINUTOS=1

# Chat - Mensagens
RATE_LIMIT_CHAT_MESSAGE_MAX=30
RATE_LIMIT_CHAT_MESSAGE_MINUTOS=1

# Chat - Salas
RATE_LIMIT_CHAT_SALA_MAX=10
RATE_LIMIT_CHAT_SALA_MINUTOS=10

# Chat - Busca de Usuários
RATE_LIMIT_BUSCA_USUARIOS_MAX=30
RATE_LIMIT_BUSCA_USUARIOS_MINUTOS=1

# Chat - Listagens (conversas e mensagens)
RATE_LIMIT_CHAT_LISTAGEM_MAX=60
RATE_LIMIT_CHAT_LISTAGEM_MINUTOS=1

# Chamados - Criação
RATE_LIMIT_CHAMADO_CRIAR_MAX=5
RATE_LIMIT_CHAMADO_CRIAR_MINUTOS=30

# Chamados - Respostas (Usuário)
RATE_LIMIT_CHAMADO_RESPONDER_MAX=10
RATE_LIMIT_CHAMADO_RESPONDER_MINUTOS=10

# Chamados - Respostas (Admin)
RATE_LIMIT_ADMIN_CHAMADO_RESPONDER_MAX=20
RATE_LIMIT_ADMIN_CHAMADO_RESPONDER_MINUTOS=5

# Admin - Download de Backups
RATE_LIMIT_BACKUP_DOWNLOAD_MAX=5
RATE_LIMIT_BACKUP_DOWNLOAD_MINUTOS=10

# Admin - Área de Backups
RATE_LIMIT_ADMIN_BACKUPS_MAX=5
RATE_LIMIT_ADMIN_BACKUPS_MINUTOS=5

# Admin - Gestão de Usuários
RATE_LIMIT_ADMIN_USUARIOS_MAX=10
RATE_LIMIT_ADMIN_USUARIOS_MINUTOS=1

# Admin - Configurações
RATE_LIMIT_ADMIN_CONFIG_MAX=10
RATE_LIMIT_ADMIN_CONFIG_MINUTOS=1

# Pagamentos - Criação
RATE_LIMIT_PAGAMENTO_CRIAR_MAX=10
RATE_LIMIT_PAGAMENTO_CRIAR_MINUTOS=10
